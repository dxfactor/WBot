# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_for_webhook

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI Whisper API (para transcripción de mensajes de voz)
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Server
PORT=3000

# Nombre del negocio (aparece en el saludo del bot)
BUSINESS_NAME=Mi Tienda

# Límite de tokens (input+output) por usuario por día — 0 o ausente = sin límite
# Ejemplo: 50000 equivale a ~$0.75 USD por usuario al día con Opus
MAX_TOKENS_USUARIO_DIA=0

# Base de datos PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=WBot
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password

# Número del vendedor (para notificaciones de pedidos y cotizaciones)
VENDEDOR_PHONE=56912345678

# Email (para notificaciones de cotizaciones)
# EMAIL_SERVICE es el servicio SMTP (gmail, outlook, etc.)
# Obtener contraseña de aplicación en: https://myaccount.google.com/apppasswords (para Gmail)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
